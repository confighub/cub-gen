{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://confighub.com/schemas/provenance-record.v1.schema.json",
  "title": "ProvenanceRecord v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provenance_id",
    "change_id",
    "generator",
    "input_hash",
    "inputs",
    "toolchain_version",
    "policy_version",
    "run_id",
    "sources",
    "artifacts",
    "outputs",
    "rendered_at"
  ],
  "properties": {
    "schema_version": {
      "const": "provenance-record.v1"
    },
    "provenance_id": {
      "type": "string",
      "pattern": "^prv_[a-z0-9]{16}$"
    },
    "change_id": {
      "type": "string",
      "pattern": "^chg_[A-Za-z0-9_\\-]{8,}$"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_id", "name", "version"],
      "properties": {
        "generator_id": {
          "type": "string",
          "pattern": "^gen_[a-z0-9]{16}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "input_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "toolchain_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_\\-]{6,}$"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "uri", "revision"],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "dry-intent",
              "dry-base",
              "dry-app",
              "gitops-config",
              "chart",
              "values",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "revision": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "uri", "digest"],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "generator-binary",
              "policy-bundle",
              "input-bundle",
              "output-bundle",
              "evidence-bundle",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "uri", "digest"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["wet-manifest", "oci-artifact", "receipt", "other"]
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "controller": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["flux", "argo", "unknown"]
        },
        "object_ref": {
          "type": "string"
        }
      }
    },
    "attestation_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "rendered_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
